{
  "name": "licitapp-chile",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "services/*",
    "frontend"
  ],
  "scripts": {
    "dev": "docker-compose -f infrastructure/docker/docker-compose.dev.yml up",
    "dev:services": "concurrently \"yarn workspace api-gateway dev\" \"yarn workspace connectors dev\" \"yarn workspace search dev\" \"yarn workspace auth dev\"",
    "dev:frontend": "yarn workspace frontend dev",
    "build": "yarn workspaces run build",
    "test": "yarn workspaces run test",
    "lint": "yarn workspaces run lint",
    "db:migrate": "yarn workspace api-gateway db:migrate",
    "db:seed": "yarn workspace api-gateway db:seed"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "typescript": "^5.3.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.50.0",
    "prettier": "^3.1.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "yarn": ">=1.22.0"
  }
}
